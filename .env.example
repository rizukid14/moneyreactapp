# Firebase Client SDK (used by the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Cloud Messaging (Push Notifications)
VITE_FIREBASE_VAPID_KEY=

# Firebase Admin SDK (used by Vercel serverless functions / cron jobs)
# Paste the full JSON content of your Firebase service account key here (or base64 encoded)
FIREBASE_SERVICE_ACCOUNT_KEY=

# OpenAI API Key (used by /api/scan for receipt OCR)
OPENAI_API_KEY=
